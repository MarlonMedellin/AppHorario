---
import { fetchMatrizFlexible } from "../services/sheetService";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import HorarioPersonalApp from "../components/HorarioPersonalApp.jsx";

// Fetch data
const rawData = await fetchMatrizFlexible();

// Limpiar para asegurar JSON stringificable
const cleanData = rawData.map(item => ({
    ...item,
    Día: item.Día || "",
    Asesor: item.Asesor || "",
    Asignatura: item.Asignatura || "",
    Hora_Inicio: item.Hora_Inicio || "",
    Hora_Fin: item.Hora_Fin || "",
    Area: item.Area || "",
    Tipo: item.Tipo || "",
    Modalidad: item.Modalidad || "",
    Ubicación_Detalle: item.Ubicación_Detalle || "",
    Sede: item.Sede || "",
    CTA: item.CTA || "",
    Link_Foto: item.Link_Foto || "",
    Estado: item.Estado || "",
    hasTypoError: item.hasTypoError || false,
    typoDetails: item.typoDetails || ""
}));
---

<DashboardLayout title="Horario Personal - HorariosQuedate">
    <script is:inline>
        // CLIENT-SIDE ROUTE PROTECTION
        (function () {
            const session = localStorage.getItem("horarios_session");
            if (!session) {
                alert("Debes iniciar sesión para acceder a esta página");
                window.location.href = "/";
            }
        })();
    </script>

    <HorarioPersonalApp client:load initialData={cleanData} />
</DashboardLayout>
