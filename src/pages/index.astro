---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import SummaryCards from "../components/dashboard/SummaryCards.astro";
import DashboardTable from "../components/Dashboard.jsx"; // Re-using the logic, but wrapped in new design
---

<DashboardLayout
	title="Quédate en Colmayor | Ingreso, Permanencia y Graduación"
>
	<div class="relative min-h-screen flex flex-col">
		<!-- Title Section -->
		<div class="mb-8 flex items-start justify-between gap-4">
			<div>
				<h1 class="text-3xl font-bold text-[var(--color-text-main)]">
					Quédate en Colmayor
				</h1>
				<p class="text-gray-500 dark:text-gray-400">
					Ingreso, Permanencia y Graduación
				</p>
			</div>
			<!-- Center: Announcement Pills + Right Actions -->
			<div
				class="hidden md:flex items-center gap-3 pt-1 flex-shrink-0 ml-auto"
			>
				<!-- Pills -->
				<div class="flex items-center gap-2">
					<div
						class="flex items-center gap-2 bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 px-3 py-1.5 rounded-full"
					>
						<span
							class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0"
						></span>
						<span
							class="text-xs font-semibold text-gray-700 dark:text-gray-200 whitespace-nowrap"
							>Inicio de asesorías</span
						>
						<span class="text-xs text-gray-400 whitespace-nowrap"
							>Martes 10 de Febrero</span
						>
					</div>
					<div
						class="flex items-center gap-2 bg-orange-50 dark:bg-orange-900/20 border border-orange-100 dark:border-orange-800 px-3 py-1.5 rounded-full"
					>
						<span
							class="w-1.5 h-1.5 rounded-full bg-orange-400 flex-shrink-0"
						></span>
						<span
							class="text-xs font-semibold text-gray-700 dark:text-gray-200 whitespace-nowrap"
							>Horario de Atención</span
						>
						<span class="text-xs text-gray-400 whitespace-nowrap"
							>L-V: 7am-8pm | Sáb: 7am-4pm</span
						>
					</div>
				</div>
				<!-- Right Actions (theme + user) -->
				<div
					class="flex items-center gap-2 ml-2 pl-3 border-l border-[var(--color-border)]"
				>
					<button
						id="theme-toggle-page"
						data-theme-toggle
						class="p-2 text-gray-400 hover:text-[var(--color-brand)] transition rounded-full hover:bg-black/5 dark:hover:bg-white/5"
						aria-label="Toggle theme"
					>
						<svg
							id="theme-icon-light-page"
							class="w-5 h-5 hidden dark:block"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
							></path>
						</svg>
						<svg
							id="theme-icon-dark-page"
							class="w-5 h-5 block dark:hidden"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
							></path>
						</svg>
					</button>
					<div class="relative group">
						<button
							id="user-menu-btn-page"
							class="flex items-center gap-2 cursor-pointer hover:bg-black/5 dark:hover:bg-white/5 p-1.5 rounded-full transition"
						>
							<div class="text-right hidden lg:block">
								<p
									class="text-sm font-bold text-[var(--color-text-main)]"
									id="user-name-page"
								>
									Profesional
								</p>
								<p class="text-xs text-gray-500">Permanencia</p>
							</div>
							<div
								class="w-9 h-9 rounded-full bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-accent)] flex items-center justify-center text-white font-bold shadow-md ring-2 ring-white dark:ring-gray-800 text-sm"
							>
								U
							</div>
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Widgets Row -->
		<SummaryCards />

		<!-- Main Layout: Table Full Width -->
		<div class="flex flex-col gap-8 mt-8 pb-12 flex-1">
			<!-- Main Content: Schedule -->
			<div class="w-full">
				<div
					class="bg-[var(--color-bg-card)] rounded-2xl shadow-sm border border-[var(--color-border)] p-6 mb-8"
				>
					<!-- Schedule Table -->
					<DashboardTable
						client:only="react"
						hideAdministrativeAreas={true}
					/>
				</div>
			</div>
		</div>
	</div>
</DashboardLayout>
