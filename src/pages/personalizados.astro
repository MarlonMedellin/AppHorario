---
import { fetchMatrizFlexible } from "../services/sheetService";
import DashboardLayout from "../layouts/DashboardLayout.astro";
import PersonalizadosApp from "../components/PersonalizadosApp.jsx";

// Fetch data
const allData = await fetchMatrizFlexible();

// Filter only personalized sessions
const personalizedData = allData.filter(
    (item) => item.Tipo && item.Tipo.toLowerCase().includes("personalizada"),
);

// Limpiar para asegurar JSON stringificable
const cleanData = personalizedData.map((item) => ({
    ...item,
    Día: item.Día || "",
    Asesor: item.Asesor || "",
    Asignatura: item.Asignatura || "",
    Hora_Inicio: item.Hora_Inicio || "",
    Hora_Fin: item.Hora_Fin || "",
    Area: item.Area || "",
    Tipo: item.Tipo || "",
    Modalidad: item.Modalidad || "",
    Ubicación_Detalle: item.Ubicación_Detalle || "",
    Sede: item.Sede || "",
    CTA: item.CTA || "",
    Link_Foto: item.Link_Foto || "",
    Estado: item.Estado || "",
    hasTypoError: item.hasTypoError || false,
    typoDetails: item.typoDetails || "",
}));
---

<DashboardLayout title="Asesorías Personalizadas - HorariosQuedate">
    <script is:inline>
        (function () {
            const session = localStorage.getItem("horarios_session");
            if (!session) {
                alert("Debes iniciar sesión para acceder a esta página");
                window.location.href = "/";
            }
        })();
    </script>

    <PersonalizadosApp client:load initialData={cleanData} />
</DashboardLayout>
