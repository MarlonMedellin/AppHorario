# .env

# ==========================================
# GESTIÓN DE DATOS (NUEVA ARQUITECTURA SUPABASE)
# ==========================================
# 1. Tu URL pública de Supabase
PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"

# 2. La llave ANÓNIMA (Para que Astro/React puedan LEER la base de datos libremente)
PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5c...tu-llave-anonima...xyz"

# 3. La llave MAESTRA/SERVICE ROLE (Oculta, JAMÁS EMPIEZA POR PUBLIC) 
# Solo usada por tu Terminal local para Forzar la Inyección desde el Excel
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsIn...tu-llave-maestra-secreta...abc"

# ==========================================
# GOOGLE SHEETS (ORIGEN SINCRONIZADOR)
# ==========================================
PUBLIC_CSV_URL_MATRIZ="https://docs.google.com/spreadsheets/d/e/2PACX.../pub?output=csv"
PUBLIC_CSV_URL_CONFIG="https://docs.google.com/spreadsheets/d/e/2PACX.../pub?output=csv"
